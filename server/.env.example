# Connection pool params (penting utk 500+ user concurrent):
#   connection_limit — max koneksi simultan Prisma → MySQL (default num_cpu*2+1)
#   pool_timeout      — detik nunggu koneksi available di pool sebelum throw
#   connect_timeout   — detik nunggu koneksi awal ke MySQL
DATABASE_URL="mysql://u123_user:password@localhost:3306/u123_webujian?connection_limit=10&pool_timeout=30&connect_timeout=10"
JWT_SECRET="ganti_dengan_random_string_minimal_32_karakter"
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://domain-anda.com"

# Upload Configuration (CMS Berita)
# Path absolut ke folder uploads di Hostinger public_html
UPLOAD_PATH="/home/u123456789/public_html/uploads/berita"
# Base URL untuk akses file upload (tanpa trailing slash)
UPLOAD_BASE_URL="https://domain-anda.com"
