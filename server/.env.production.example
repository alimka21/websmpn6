# File: server/.env.production.example (untuk BACKEND)

# Backend environment variables
# Database MySQL Hostinger
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Connection pool params (penting utk skala ujian serentak):
#   connection_limit=15  — max koneksi simultan Prisma → MySQL. Hostinger
#                          shared umumnya batas 25-50 per user; 15 aman.
#   pool_timeout=20      — detik nunggu koneksi available sebelum error.
#   connect_timeout=10   — detik nunggu koneksi awal ke MySQL.
DATABASE_URL="mysql://u123_user:password@localhost:3306/u123_webujian?connection_limit=10&pool_timeout=30&connect_timeout=10"

# JWT secret - GENERATE: openssl rand -base64 48
# WAJIB ganti dengan random string minimal 32 karakter
JWT_SECRET="ganti_dengan_random_string_minimal_32_karakter"

# Server port (Hostinger override otomatis di production)
PORT=3001

# Environment
NODE_ENV=production

# Frontend URL untuk CORS - HARUS persis dengan domain frontend (TIDAK ADA SLASH DI AKHIR)
FRONTEND_URL="https://domain-anda.com"
