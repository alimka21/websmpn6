# Frontend Environment Variables

# API URL (development: proxy via vite, production: Hostinger subdomain)
VITE_API_URL=https://api.domain-anda.com

# Gemini AI API Key (untuk fitur AI jika ada)
GEMINI_API_KEY=your_gemini_api_key_here

# Site Configuration (untuk meta tags SEO)
VITE_SITE_NAME=Nama Sekolah Anda
VITE_APP_URL=https://domain-anda.com
